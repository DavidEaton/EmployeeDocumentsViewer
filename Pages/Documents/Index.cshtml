@page "/documents"
@model EmployeeDocumentsViewer.Pages.Documents.IndexModel
@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label for="companySelect" class="form-label">Company</label>
        <select id="companySelect" class="form-select">
            <option value="">-- Select a company --</option>
            @foreach (var company in Model.Companies)
            {
                <option value="@company.Value">@company.Text</option>
            }
        </select>
    </div>
</div>

<p class="document-grid-hint mt-2 mb-2" id="document-grid-hint">Tip: Click any row or use the <strong>Open</strong> column to open or download that document's PDF.</p>
<div id="document-grid"></div>

@section Scripts
{
    <link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/luxon@3.5.0/build/global/luxon.min.js"></script>
    <script src="https://unpkg.com/tabulator-tables@6.3.0/dist/js/tabulator.min.js"></script>
    <script>
        const companySelect = document.getElementById('companySelect');
        const getBlobName = (rowData) => rowData?.blobName ?? rowData?.BlobName ?? null;
        const getDocumentOpenUrl = (rowData) => {
            const blobNameValue = getBlobName(rowData);
            if (!rowData || !blobNameValue) {
                return null;
            }

            const resolvedCompanyKey = rowData.companyKey || rowData.CompanyKey || companySelect.value;
            if (!resolvedCompanyKey) {
                return null;
            }

            const company = encodeURIComponent(String(resolvedCompanyKey));
            const blobName = encodeURIComponent(String(blobNameValue));
            return `/api/documents/open/${company}?blobName=${blobName}`;
        };

        const table = new Tabulator('#document-grid', {
            layout: 'fitColumns',
            pagination: true,
            paginationMode: 'remote',
            filterMode: 'remote',
            sortMode: 'remote',
            paginationSize: 25,
            paginationSizeSelector: [10, 25, 50, 100],
            paginationCounter: function (pageSize, currentRow, currentPage, totalRows, totalPages) {
                if (totalRows === 0) {
                    return 'Showing 0 to 0 of 0 entries';
                }

                const rowsOnPage = table.getDataCount();
                const firstRow = ((currentPage - 1) * pageSize) + 1;
                const lastRow = Math.min(firstRow + rowsOnPage - 1, totalRows);
                return `Showing ${firstRow} to ${lastRow} of ${totalRows.toLocaleString()} entries`;
            },
            ajaxURL: '/api/documents/list',
            ajaxConfig: 'POST',
            ajaxContentType: 'json',
            ajaxRequestFunc: async (url, config, params) => {
                if (!companySelect.value) return { last_page: 1, data: [] };

                const tabulatorFilters = table.getHeaderFilters();
                const tabulatorSorters = table.getSorters();

                const payload = {
                    companyKey: companySelect.value,
                    page: Number.isFinite(params?.page) ? params.page : 1,
                    size: Number.isFinite(params?.size) ? params.size : table.getPageSize(),
                    sorters: tabulatorSorters
                        .filter(s => s && typeof s.field === 'string')
                        .map(s => ({
                            field: s.field,
                            dir: s.dir === 'desc' ? 'desc' : 'asc'
                        })),
                    filters: tabulatorFilters
                        .filter(f => f && typeof f.field === 'string')
                        .map(f => ({
                            field: f.field,
                            value: f.value == null ? null : String(f.value)
                        }))
                };

                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const raw = await response.json();
                const normalized = raw?.response ?? raw;
                const pageCount = Number(
                    normalized?.last_page
                    ?? normalized?.lastPage
                    ?? normalized?.lastpage
                    ?? 1
                );
                const rows = Array.isArray(normalized?.data)
                    ? normalized.data
                    : (Array.isArray(normalized?.items) ? normalized.items : []);
                const filteredCount = Number(
                    normalized?.filtered_count
                    ?? normalized?.filteredCount
                    ?? normalized?.total_count
                    ?? normalized?.totalCount
                    ?? rows.length
                );

                return {
                    ...normalized,
                    last_page: Number.isFinite(pageCount) && pageCount > 0 ? pageCount : 1,
                    last_row: Number.isFinite(filteredCount) && filteredCount >= 0 ? filteredCount : rows.length,
                    data: rows
                };
            },
            rowClick: (e, row) => {
                const target = e.target;
                if (target && target.closest && target.closest('a')) {
                    return;
                }

                const openUrl = getDocumentOpenUrl(row.getData());
                if (openUrl) {
                    window.open(openUrl, '_blank', 'noopener');
                }
            },
            rowFormatter: (row) => {
                const rowElement = row.getElement();
                rowElement.style.cursor = getDocumentOpenUrl(row.getData()) ? 'pointer' : '';
                rowElement.title = getDocumentOpenUrl(row.getData())
                    ? 'Click anywhere on this row to open or download the PDF'
                    : '';
            },
            columns: [
                { title: 'Employee ID', field: 'employeeId', headerFilter: 'input', headerSort: true },
                { title: 'Employee Name', field: 'employeeName', headerFilter: 'input', headerSort: true },
                { title: 'Home Department', field: 'department', headerFilter: 'input', headerSort: true },
                { title: 'Document Type', field: 'documentType', headerFilter: 'input', headerSort: true },
                { title: 'Year', field: 'year', headerFilter: 'input', headerSort: true },
                {
                    title: 'Termination Date',
                    field: 'terminationDate',
                    formatter: (cell) => {
                        const value = cell.getValue();
                        if (!value) return '';

                        const parsed = luxon.DateTime.fromISO(String(value));
                        return parsed.isValid ? parsed.toFormat('yyyy-MM-dd') : String(value);
                    },
                    headerFilter: 'input',
                    headerSort: true
                },
                {
                    title: 'Open',
                    field: 'blobName',
                    headerSort: false,
                    headerFilter: false,
                    hozAlign: 'center',
                    width: 95,
                    formatter: (cell) => {
                        const openUrl = getDocumentOpenUrl(cell.getRow().getData());
                        if (!openUrl) {
                            return '';
                        }
                        return '<span class="open-document-trigger" aria-hidden="true">📄 Open</span>';
                    },
                    cellClick: (e, cell) => {
                        e.stopPropagation();
                        const openUrl = getDocumentOpenUrl(cell.getRow().getData());
                        if (openUrl) {
                            window.open(openUrl, '_blank', 'noopener');
                        }
                    }
                }
            ]
        });

        companySelect.addEventListener('change', () => table.setData());
    </script>
}
