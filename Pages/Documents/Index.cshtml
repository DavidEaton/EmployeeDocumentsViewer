@page "/documents"
@model EmployeeDocumentsViewer.Pages.Documents.IndexModel
@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label for="companySelect" class="form-label">Company</label>
        <select id="companySelect" class="form-select">
            <option value="">-- Select a company --</option>
            @foreach (var company in Model.Companies)
            {
                <option value="@company.Value">@company.Text</option>
            }
        </select>
    </div>
</div>

<div id="document-grid"></div>

@section Scripts
{
    <link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet">
    <script src="https://unpkg.com/tabulator-tables@6.3.0/dist/js/tabulator.min.js"></script>
    <script>
        const companySelect = document.getElementById('companySelect');
        const table = new Tabulator('#document-grid', {
            layout: 'fitColumns',
            pagination: true,
            paginationMode: 'remote',
            filterMode: 'remote',
            sortMode: 'remote',
            paginationSize: 50,
            dataReceiveParams: {
                last_page: 'lastPage',
                data: 'data'
            },
            ajaxURL: '/api/documents/list',
            ajaxConfig: 'POST',
            ajaxContentType: 'json',
            ajaxRequestFunc: async (url, config, params) => {
                if (!companySelect.value) return { lastPage: 1, data: [] };

                const payload = {
                    companyKey: companySelect.value,
                    page: params.page ?? 1,
                    size: params.size ?? 50,
                    sorters: params.sorters ?? params.sorter ?? [],
                    filters: params.filters ?? params.filter ?? []
                };

                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                return await response.json();
            },
            columns: [
                { title: 'Employee ID', field: 'employeeId', headerFilter: 'input' },
                { title: 'Employee Name', field: 'employeeName', headerFilter: 'input' },
                { title: 'Home Department', field: 'department', headerFilter: 'input' },
                { title: 'Document Type', field: 'documentType', headerFilter: 'input' },
                { title: 'Year', field: 'year', headerFilter: 'input' },
                { title: 'Termination Date', field: 'terminationDate', formatter: 'datetime', formatterParams: { outputFormat: 'yyyy-MM-dd' }, headerFilter: 'input' }
            ]
        });

        companySelect.addEventListener('change', () => table.setData());
    </script>
}
