@page "/documents"
@model EmployeeDocumentsViewer.Pages.Documents.IndexModel
@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-4">
        <label for="companySelect" class="form-label">Company</label>
        <select id="companySelect" class="form-select">
            <option value="">-- Select a company --</option>
            @foreach (var company in Model.Companies)
            {
                <option value="@company.Value">@company.Text</option>
            }
        </select>
    </div>
</div>

<p class="document-grid-hint mt-2 mb-2" id="document-grid-hint">Tip: Click any row or use the open icon column to open or download that document's PDF.</p>
<div id="document-grid"></div>

@section Scripts
{
    <link href="https://unpkg.com/tabulator-tables@6.3.0/dist/css/tabulator.min.css" rel="stylesheet">
    <link id="tabulator-dark-theme" href="https://cdnjs.cloudflare.com/ajax/libs/tabulator/6.3.1/css/tabulator_site_dark.css" rel="stylesheet" disabled>
    <script src="https://cdn.jsdelivr.net/npm/luxon@3.5.0/build/global/luxon.min.js"></script>
    <script src="https://unpkg.com/tabulator-tables@6.3.0/dist/js/tabulator.min.js"></script>

    <style>
        #document-grid .document-row-openable {
            cursor: pointer;
        }

        #document-grid .document-row-openable:hover .tabulator-cell {
            background-color: var(--app-grid-row-hover, rgba(0, 0, 0, 0.04));
        }

        #document-grid .open-document-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: inherit;
            text-decoration: none;
        }

        #document-grid .open-document-missing {
            color: #777;
            font-style: italic;
            white-space: nowrap;
        }

        #document-grid .open-document-icon {
            display: inline-block;
            color: currentColor;
            line-height: 0;
        }

        #document-grid .open-document-icon svg {
            width: 16px;
            height: 16px;
            stroke: currentColor;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        #document-grid .open-header-icon svg {
            width: 18px;
            height: 18px;
        }
    </style>

    <script>
        const companySelect = document.getElementById('companySelect');
        const openDocumentTooltip = 'Click anywhere on this row to open or download the PDF';
        const openDocumentGlyph = `
            <span class="open-document-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M14 4h6v6"></path>
                    <path d="M10 14L20 4"></path>
                    <path d="M20 14v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h5"></path>
                </svg>
            </span>`;
        const openHeaderGlyph = openDocumentGlyph.replace(
            'open-document-icon',
            'open-document-icon open-header-icon'
        );

        const getBlobName = (rowData) =>
            rowData?.blobName
            ?? rowData?.BlobName
            ?? rowData?.blob
            ?? rowData?.Blob
            ?? null;

        const getCompanyKey = (rowData) =>
            rowData?.companyKey
            ?? rowData?.CompanyKey
            ?? companySelect?.value
            ?? null;

        const getDocumentOpenUrl = (rowData) => {
            const companyKey = getCompanyKey(rowData);
            const blobName = getBlobName(rowData);

            if (!companyKey || !blobName) {
                return null;
            }

            return `/api/documents/open/${encodeURIComponent(String(companyKey))}?blobName=${encodeURIComponent(String(blobName))}`;
        };

        const logRowDiagnostic = (rowData, reason) => {
            console.warn(`Document row is not openable: ${reason}`, {
                rowData,
                companyKey: getCompanyKey(rowData),
                blobName: getBlobName(rowData),
                availableFields: rowData ? Object.keys(rowData) : []
            });
        };

        const openDocument = (rowData) => {
        const openUrl = getDocumentOpenUrl(rowData);

        if (!openUrl) {
            logRowDiagnostic(rowData, 'missing companyKey or blobName');
            return;
        }

        const openedWindow = window.open(openUrl, '_blank', 'noopener,noreferrer');

        if (openedWindow) {
            openedWindow.opener = null;
        }
        };

        const makeOpenColumnFormatter = (cell) => {
            const rowData = cell.getRow().getData();
            const openUrl = getDocumentOpenUrl(rowData);

            if (!openUrl) {
                return `<span class="open-document-missing" title="This row does not include blobName/companyKey data">No PDF</span>`;
            }

            return `<a class="open-document-link"
                       href="${openUrl}"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="Open PDF"
                       title="${openDocumentTooltip}">${openDocumentGlyph}</a>`;
        };


        const applyTabulatorTheme = () => {
            const isDarkTheme = document.body.classList.contains('theme-dark');
            const tabulatorElement = document.querySelector('#document-grid .tabulator');
            const tabulatorDarkStylesheet = document.getElementById('tabulator-dark-theme');

            if (tabulatorDarkStylesheet) {
                tabulatorDarkStylesheet.disabled = !isDarkTheme;
            }

            if (!tabulatorElement) {
                return;
            }

            tabulatorElement.classList.toggle('tabulator_site_dark', isDarkTheme);
        };

        const makeCellClickHandler = (e, cell) => {
            const target = e.target;

            if (target?.closest?.('a, button, input, select, textarea')) {
                return;
            }

            openDocument(cell.getRow().getData());
        };

        let gridViewportAnchor = null;
        let shouldRestoreGridViewport = false;
        const gridSettingsStorageKey = 'employee-documents-grid-settings-v1';
        let isTableBuilt = false;
        let isRestoringGridSettings = false;
        let restoredInitialGridSettings = false;

        const saveGridSettings = () => {
            if (!isTableBuilt || isRestoringGridSettings) {
                return;
            }

            const sorters = table.getSorters()
                .filter(sorter => sorter && typeof sorter.field === 'string')
                .map(sorter => ({
                    field: sorter.field,
                    dir: sorter.dir === 'desc' ? 'desc' : 'asc'
                }));

            const filters = table.getHeaderFilters()
                .filter(filter => filter && typeof filter.field === 'string')
                .map(filter => ({
                    field: filter.field,
                    value: filter.value == null ? '' : String(filter.value)
                }));

            const columns = table.getColumns()
                .map(column => ({
                    field: column.getField(),
                    width: column.getWidth()
                }))
                .filter(column => typeof column.field === 'string' && Number.isFinite(column.width));

            const settings = {
                pageSize: table.getPageSize(),
                page: table.getPage(),
                sorters,
                filters,
                columns,
                scrollY: window.scrollY
            };

            window.localStorage.setItem(gridSettingsStorageKey, JSON.stringify(settings));
        };

        const getGridSettings = () => {
            try {
                const serialized = window.localStorage.getItem(gridSettingsStorageKey);
                if (!serialized) {
                    return null;
                }

                const parsed = JSON.parse(serialized);
                return parsed && typeof parsed === 'object' ? parsed : null;
            } catch {
                return null;
            }
        };

        const persistedGridSettings = getGridSettings();
        const initialPaginationSize = Number.isFinite(persistedGridSettings?.pageSize) && persistedGridSettings.pageSize > 0
            ? persistedGridSettings.pageSize
            : 25;
        const initialSort = Array.isArray(persistedGridSettings?.sorters)
            ? persistedGridSettings.sorters
                .filter(sorter => sorter && typeof sorter.field === 'string')
                .map(sorter => ({
                    field: sorter.field,
                    dir: sorter.dir === 'desc' ? 'desc' : 'asc'
                }))
            : [];
        const initialHeaderFilter = Array.isArray(persistedGridSettings?.filters)
            ? persistedGridSettings.filters
                .filter(filter => filter && typeof filter.field === 'string')
                .map(filter => ({
                    field: filter.field,
                    value: filter.value == null ? '' : String(filter.value)
                }))
            : [];

        const captureGridViewportAnchor = () => {
            const gridElement = document.getElementById('document-grid');

            if (!gridElement) {
                gridViewportAnchor = null;
                return;
            }

            gridViewportAnchor = {
                gridTop: gridElement.getBoundingClientRect().top,
                scrollY: window.scrollY
            };
        };

        const restoreGridViewportAnchor = () => {
            if (!shouldRestoreGridViewport || !gridViewportAnchor) {
                return;
            }

            const gridElement = document.getElementById('document-grid');

            if (!gridElement) {
                gridViewportAnchor = null;
                return;
            }

            const currentGridTop = gridElement.getBoundingClientRect().top;
            const scrollAdjustment = currentGridTop - gridViewportAnchor.gridTop;

            if (Math.abs(scrollAdjustment) > 1) {
                window.scrollTo({
                    top: gridViewportAnchor.scrollY + scrollAdjustment,
                    behavior: 'auto'
                });
            }

            shouldRestoreGridViewport = false;
            gridViewportAnchor = null;
        };

        const applyColumnWidths = (settings) => {
            if (!Array.isArray(settings?.columns) || settings.columns.length === 0) {
                return;
            }

            for (const columnSetting of settings.columns) {
                if (!columnSetting || typeof columnSetting.field !== 'string' || !Number.isFinite(columnSetting.width)) {
                    continue;
                }

                const column = table.getColumn(columnSetting.field);
                if (column) {
                    column.setWidth(columnSetting.width);
                }
            }
        };

        const applyHeaderFilters = (settings) => {
            if (!Array.isArray(settings?.filters)) {
                return;
            }

            for (const filter of settings.filters) {
                if (!filter || typeof filter.field !== 'string') {
                    continue;
                }

                table.setHeaderFilterValue(filter.field, filter.value == null ? '' : String(filter.value));
            }
        };

        const scheduleGridViewportRestore = () => {
            window.requestAnimationFrame(() => {
                window.requestAnimationFrame(() => {
                    restoreGridViewportAnchor();
                });
            });
        };


        const sanitizeDigits = (value) => String(value ?? '').replace(/\D+/g, '');

        const buildNumericHeaderFilter = ({ maxDigits, exactDigits = false } = {}) => (cell, onRendered, success, cancel) => {
            const input = document.createElement('input');
            input.type = 'text';
            input.inputMode = 'numeric';
            input.autocomplete = 'off';
            input.className = 'tabulator-header-filter';

            if (Number.isFinite(maxDigits) && maxDigits > 0) {
                input.maxLength = maxDigits;
            }

            if (exactDigits && Number.isFinite(maxDigits) && maxDigits > 0) {
                input.minLength = maxDigits;
                input.placeholder = `${maxDigits} digits`;
            }

            const commit = () => {
                const digits = sanitizeDigits(input.value);
                const boundedDigits = Number.isFinite(maxDigits) && maxDigits > 0
                    ? digits.slice(0, maxDigits)
                    : digits;

                input.value = boundedDigits;

                if (exactDigits && Number.isFinite(maxDigits) && boundedDigits.length > 0 && boundedDigits.length !== maxDigits) {
                    success('');
                    return;
                }

                success(boundedDigits);
            };

            onRendered(() => {
                input.value = sanitizeDigits(cell.getValue());
            });

            input.addEventListener('input', () => {
                const digits = sanitizeDigits(input.value);
                input.value = Number.isFinite(maxDigits) && maxDigits > 0
                    ? digits.slice(0, maxDigits)
                    : digits;
                commit();
            });

            input.addEventListener('change', commit);
            input.addEventListener('blur', commit);
            input.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    commit();
                } else if (event.key === 'Escape') {
                    cancel();
                }
            });

            return input;
        };

        const table = new Tabulator('#document-grid', {
            layout: 'fitColumns',
            pagination: true,
            paginationMode: 'remote',
            filterMode: 'remote',
            sortMode: 'remote',
            paginationSize: initialPaginationSize,
            paginationSizeSelector: [10, 25, 50, 100],
            initialSort,
            initialHeaderFilter,

            paginationCounter: function (pageSize, currentRow, currentPage, totalRows, totalPages) {
                if (totalRows === 0) {
                    return 'Showing 0 to 0 of 0 entries';
                }

                const rowsOnPage = table.getDataCount();
                const firstRow = ((currentPage - 1) * pageSize) + 1;
                const lastRow = Math.min(firstRow + rowsOnPage - 1, totalRows);

                return `Showing ${firstRow} to ${lastRow} of ${totalRows.toLocaleString()} entries`;
            },

            ajaxURL: '/api/documents/list',
            ajaxConfig: 'POST',
            ajaxContentType: 'json',

            ajaxRequestFunc: async (url, config, params) => {
                if (!companySelect.value) {
                    return {
                        last_page: 1,
                        last_row: 0,
                        data: []
                    };
                }

                const payload = {
                    companyKey: companySelect.value,
                    page: Number.isFinite(params?.page) ? params.page : 1,
                    size: Number.isFinite(params?.size) ? params.size : table.getPageSize(),

                    sorters: table.getSorters()
                        .filter(sorter => sorter && typeof sorter.field === 'string')
                        .map(sorter => ({
                            field: sorter.field,
                            dir: sorter.dir === 'desc' ? 'desc' : 'asc'
                        })),

                    filters: table.getHeaderFilters()
                        .filter(filter => filter && typeof filter.field === 'string')
                        .map(filter => ({
                            field: filter.field,
                            value: filter.value == null ? null : String(filter.value)
                        }))
                };

                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    throw new Error(`Document list request failed with HTTP ${response.status}.`);
                }

                const raw = await response.json();
                const normalized = raw?.response ?? raw;

                const rows = Array.isArray(normalized?.data)
                    ? normalized.data
                    : Array.isArray(normalized?.items)
                        ? normalized.items
                        : [];

                const pageCount = Number(
                    normalized?.last_page
                    ?? normalized?.lastPage
                    ?? normalized?.lastpage
                    ?? 1
                );

                const filteredCount = Number(
                    normalized?.filtered_count
                    ?? normalized?.filteredCount
                    ?? normalized?.total_count
                    ?? normalized?.totalCount
                    ?? rows.length
                );

                return {
                    ...normalized,
                    last_page: Number.isFinite(pageCount) && pageCount > 0 ? pageCount : 1,
                    last_row: Number.isFinite(filteredCount) && filteredCount >= 0 ? filteredCount : rows.length,
                    data: rows
                };
            },

            rowFormatter: (row) => {
                const rowData = row.getData();
                const openUrl = getDocumentOpenUrl(rowData);
                const rowElement = row.getElement();

                rowElement.classList.toggle('document-row-openable', Boolean(openUrl));
                rowElement.title = openUrl ? openDocumentTooltip : 'This row is missing blobName/companyKey data.';

                for (const cell of row.getCells()) {
                    cell.getElement().title = rowElement.title;
                }
            },

            columns: [
                { title: 'EeId', field: 'employeeId', headerFilter: buildNumericHeaderFilter(), headerSort: true, minWidth: 80, maxWidth: 120, widthShrink: 3, cellClick: makeCellClickHandler },
                { title: 'Employee Name', field: 'employeeName', headerFilter: 'input', headerSort: true, cellClick: makeCellClickHandler },
                { title: 'Home Department', field: 'department', headerFilter: 'input', headerSort: true, cellClick: makeCellClickHandler },
                { title: 'Document Type', field: 'documentType', headerFilter: 'input', headerSort: true, cellClick: makeCellClickHandler },
                { title: 'Year', field: 'year', headerFilter: buildNumericHeaderFilter({ maxDigits: 4, exactDigits: true }), headerSort: true, minWidth: 70, maxWidth: 90, widthShrink: 3, cellClick: makeCellClickHandler },
                {
                    title: 'Status',
                    field: 'terminationDate',
                    formatter: (cell) => {
                        const value = cell.getValue();

                        if (!value) {
                            return 'Active';
                        }

                        const parsed = luxon.DateTime.fromISO(String(value));

                        return parsed.isValid
                            ? parsed.toLocaleString(luxon.DateTime.DATE_SHORT)
                            : String(value);
                    },
                    headerFilter: 'input',
                    headerSort: true,
                    minWidth: 70, maxWidth: 90, widthShrink: 3,
                    cellClick: makeCellClickHandler
                },
                {
                    title: '',
                    field: 'blobName',
                    width: 56,
                    minWidth: 56,
                    maxWidth: 64,
                    hozAlign: 'center',
                    headerHozAlign: 'center',
                    headerSort: false,
                    headerFilter: false,
                    titleFormatter: () => `<span aria-label="Open PDF" title="Open PDF">${openHeaderGlyph}</span>`,
                    formatter: makeOpenColumnFormatter,
                    cellClick: (e, cell) => {
                        e.stopPropagation();
                        openDocument(cell.getRow().getData());
                    }
                }
            ]
        });

        table.on('tableBuilt', () => {
            applyTabulatorTheme();
            isTableBuilt = true;

            if (restoredInitialGridSettings) {
                return;
            }

            restoredInitialGridSettings = true;
            const settings = persistedGridSettings;

            if (!settings) {
                return;
            }

            isRestoringGridSettings = true;

            applyColumnWidths(settings);

            if (Number.isFinite(settings.page) && settings.page > 0) {
                table.setPage(settings.page)
                    .catch(() => {
                        // Ignore invalid/out-of-range saved pages.
                    })
                    .finally(() => {
                        isRestoringGridSettings = false;
                    });
            } else {
                isRestoringGridSettings = false;
            }

            if (Number.isFinite(settings.scrollY) && settings.scrollY >= 0) {
                window.requestAnimationFrame(() => {
                    window.scrollTo({ top: settings.scrollY, behavior: 'auto' });
                });
            }
        });

        table.on('pageLoaded', scheduleGridViewportRestore);

        document.addEventListener('app:themechanged', applyTabulatorTheme);
        applyTabulatorTheme();

        table.on('rowClick', (e, row) => {
            const target = e.target;
            if (target?.closest?.('a, button, input, select, textarea')) {
                return;
            }

            openDocument(row.getData());
        });

        companySelect.addEventListener('change', () => {
            const settings = getGridSettings();

            isRestoringGridSettings = true;
            table.setData()
                .finally(() => {
                    applyColumnWidths(settings);
                    applyHeaderFilters(settings);
                    isRestoringGridSettings = false;
                    saveGridSettings();
                });
        });

        table.on('pageSizeChanged', saveGridSettings);
        table.on('columnResized', saveGridSettings);
        table.on('dataFiltered', saveGridSettings);
        table.on('dataSorted', saveGridSettings);
        table.on('pageLoaded', saveGridSettings);
        window.addEventListener('scroll', () => {
            if (!isTableBuilt || isRestoringGridSettings) {
                return;
            }
            saveGridSettings();
        }, { passive: true });

        document.getElementById('document-grid')?.addEventListener('pointerdown', (event) => {
            const pagerControl = event.target?.closest?.('.tabulator-page, .tabulator-page-size');

            if (!pagerControl) {
                return;
            }

            captureGridViewportAnchor();
            shouldRestoreGridViewport = true;
        }, true);

        document.getElementById('document-grid')?.addEventListener('keydown', (event) => {
            if (event.key !== 'Enter' && event.key !== ' ') {
                return;
            }

            const pagerControl = event.target?.closest?.('.tabulator-page, .tabulator-page-size');

            if (!pagerControl) {
                return;
            }

            captureGridViewportAnchor();
            shouldRestoreGridViewport = true;
        }, true);

        document.getElementById('document-grid')?.addEventListener('click', (event) => {
            const pagerAnchor = event.target?.closest?.('.tabulator-page[href="#"], .tabulator-page-size[href="#"]');
            if (!pagerAnchor) {
                return;
            }

            event.preventDefault();
        }, true);
    </script>
}
